weap_ammo=0;
if !variable_instance_exists(id,"weap_owner")
weap_owner=noone; //weapons almost always never hits their owner
if !variable_instance_exists(id,"weap_target")
weap_target=noone; //weapons almost always never hits their owner
if !variable_instance_exists(id,"weap_proj")
