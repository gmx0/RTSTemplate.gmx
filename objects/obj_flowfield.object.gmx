  <events>
    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>randomize();

gridSize = 32;
width = room_width div gridSize
height = room_height div gridSize;

grid = ds_grid_create(width, height);

for (var xx=0;xx&lt;width;++xx)
{
    for (var yy=0;yy&lt;height;++yy)
    {
        var node = instance_create(0,0,obj_node);
        node.x = xx;
        node.y = yy;
        node.visited = false;
        node.walkable = choose(true, true, true, false);
        node.parent = undefined;
        
        instance_deactivate_object(node);

        ds_grid_add(grid, xx, yy, node);
    }
}

//find a default target node that is walkable
do 
{
    var tx = random_range(0, room_width) div gridSize;
    var ty = random_range(0, room_height) div gridSize;
    targetNode = ds_grid_get(grid, tx, ty);
}
until (targetNode.walkable);

//calculate the flowfield
scr_calculateFlowField(grid, targetNode);
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if (mouse_check_button_pressed(mb_left)) //set valid target node
{
    var xx = mouse_x div gridSize;
    var yy = mouse_y div gridSize;
    var node = ds_grid_get(grid, xx, yy);
    if (node.walkable)
    {
        targetNode = node;
        scr_calculateFlowField(grid, targetNode);
    }
}

if (mouse_check_button_pressed(mb_right)) //create thing
{
    var xx = mouse_x div gridSize;
    var yy = mouse_y div gridSize;
    var node = ds_grid_get(grid, xx, yy);
    if (node.walkable)
    {
        instance_create(xx*gridSize+gridSize/2,yy*gridSize+gridSize/2,obj_thing);
    }
}

if (mouse_check_button_pressed(mb_middle)) //adjust walkable/non-walkable node
{
    var xx = mouse_x div gridSize;
    var yy = mouse_y div gridSize;
    var node = ds_grid_get(grid, xx, yy);
    node.walkable = !node.walkable;
    scr_calculateFlowField(grid, targetNode);
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_set_color(c_black);
for(var i=0;i&lt;width;++i)
{
    draw_line(i*gridSize, 0, i*gridSize, room_height);
}

for(var i=0;i&lt;height;++i)
{
    draw_line(0, i*gridSize, room_width, i*gridSize);
}


draw_set_color(c_green);
draw_rectangle(targetNode.x*gridSize, targetNode.y*gridSize, (targetNode.x+1)*gridSize, (targetNode.y+1)*gridSize, false);
draw_set_color(c_black);


for (var xx=0;xx&lt;width;++xx)
{
    for (var yy=0;yy&lt;height;++yy)
    {
        var node = ds_grid_get(grid, xx, yy);
        
        if (!node.walkable)
        {
            draw_rectangle(node.x*gridSize, node.y*gridSize, (node.x+1)*gridSize, (node.y+1)*gridSize, false);
        }
        if (node.parent != undefined)
        {
            var x1 = node.x*gridSize+gridSize/2;
            var y1 = node.y*gridSize+gridSize/2;
            var x2 = node.parent.x*gridSize+gridSize/2;
            var y2 = node.parent.y*gridSize+gridSize/2;
            draw_arrow(x1,y1,x2,y2,8);
        }
    }
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
  </events>
