            <kind>1</kind>
            <string>//Handles targeting lists
//should it be a grid?
//manhattan distance? faster square root?

targeting_map_init();

//player targeting
var i;
for (i=0;i&lt;array_length_1d(global.player);i+=1;)
targeting_map_list_create("Player "+string(i));

//terrain targeting
targeting_map_list_create("Land");
targeting_map_list_create("Air");
targeting_map_list_create("Sea");

//unit type targeting
targeting_map_list_create("Structural");
targeting_map_list_create("Bipedal");
targeting_map_list_create("Terrestrial");
targeting_map_list_create("Aerial");
targeting_map_list_create("Naval");

//structure type targeting
targeting_map_list_create("Power Plant");

//Invisible stealth
targeting_map_list_create("Cloak");
//Spies
targeting_map_list_create("Disguise");
</string>
          </argument>
        </arguments>
      </action>
    </event>
