    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>templates_init();

gui_owner=noone; //owner is a unit or player character, non-UI object, to get information from
//usually if an owner dies/is destroyed, the GUI object will be destroyed as well, or switch owners

gui_anchor=noone; //anchor is another GUI object this attaches to, useful for attaching buttons to dialog boxes, among other things
gui_anchor_xr=0; //relative
gui_anchor_yr=0; //relative
//visibility is tied to anchor
//if an anchor is closed, delete itself, similar to owner

gui_select=false; //if selected, this gui can be clicked on and interacted with, otherwise cannot be interacted with

gui_text="";
gui_text_xr=0; //relative
gui_text_yr=0; //relative
gui_amount=0; //a variable that is shown, like number of units queued, or health

gui_width=sprite_width; //x + w
gui_height=sprite_height; //y + h

gui_xscale=image_xscale;
gui_yscale=image_yscale;

gui_draggable=false; //can be dragged?
gui_drag=false; //is it being dragged right now?

gui_scalable=false; //can be scaled by mouse?
gui_scale=false; //is it being scaled right now?
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="2">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//anchored to another object
if instance_exists(gui_anchor)
{
x=gui_anchor.x+gui_anchor_xr;
y=gui_anchor.y+gui_anchor_yr;
}

//dragged by the mouse
if gui_drag
{
x=mouse_x;
y=mouse_y;
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
