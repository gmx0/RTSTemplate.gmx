    <event eventtype="8" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//might scrap this and put it on the Draw GUI event
//remember to use window_mouse_get_x/y or whatever

if view_isoutside(x,y,x+(gui_width*gui_xscale),y+(gui_height*gui_yscale),view_current)
exit;

draw_rectangle(x,y,x+(gui_width*gui_xscale),y+(gui_height*gui_yscale),true); //draw the UI borders

draw_text(x+gui_text_xr,y+gui_text_yr,gui_text); //draw the main text

draw_self(); //draw the sprite
</string>
          </argument>
        </arguments>
      </action>
    </event>
