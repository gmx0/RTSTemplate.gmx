            <kind>1</kind>
            <string>player_state=player_states.plyr_command;

player_command_x=x;
player_command_y=y;

if instance_exists(player_unit)
with player_unit
{
 if unit_select
 {
 unit_command_x=other.player_command_x;
 unit_command_y=other.player_command_y;
 }
}
</string>
          </argument>
        </arguments>
      </action>
