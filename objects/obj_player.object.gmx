        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//select units in select box
if instance_exists(player_unit)
with player_unit
{
 if 
 x&lt;=max(other.x,other.player_select_x) &amp;&amp;
 y&lt;=max(other.y,other.player_select_y) &amp;&amp;
 x&gt;=min(other.x,other.player_select_x) &amp;&amp;
 y&gt;=min(other.y,other.player_select_y)
 {
 unit_select=true;
 with other
 select_unit(other.id);
 }
}

player_state=player_states.plyr_idle;
</string>
          </argument>
        </arguments>
      </action>
    </event>
