        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>player_state=player_states.plyr_select;

//deselect all player units
if instance_exists(player_unit)
with player_unit
{
 unit_select=false;
}

select_clear();

player_select_x=x;
player_select_y=y;
</string>
          </argument>
        </arguments>
      </action>
