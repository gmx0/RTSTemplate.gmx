        <arguments>
          <argument>
            <kind>1</kind>
            <string>if(net_is_server())
    exit;
var keysDown = 0;
for(var i = 0; i &lt; ds_list_size(keys); i ++)
{
    if(keyboard_check(ds_list_find_value(keys, i)))
    {
        keysDown += power(2, i);
    }
}

if(preKeys != keysDown)
{
    net_packet_create("Keys");
    net_packet_add(ds_list_size(keys), keysDown);
    net_packet_send();
}
preKeys = keysDown;
</string>
