    <event eventtype="8" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>var col = draw_get_color();
draw_set_color(c_white);
//Draw chat
for(var i = 0; i &lt; ds_list_size(chat); i++)
{
    draw_text(x, y - 30 - 30 * i, ds_list_find_value(chat, i));
}
//Draw current text
draw_text(x, y, keyboard_string);
if(writing)
{
    //Draw cursor
    draw_line(x + string_width(keyboard_string), y + string_height("Q"), x + string_width(keyboard_string) + 6, y + string_height("Q"));
}
draw_set_color(col);
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="9" enumb="1">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//Check if user wants to send, or start writing text
if(keyboard_check(vk_enter))
{
    writing = !writing;
    //Do user want to send?
    if(writing == false &amp;&amp; keyboard_string != "")
    {
        //Send text
        if(net_is_client())
        {
            net_packet_create("Chat");
            net_packet_add(keyboard_string);
            net_packet_send();
        }
        else
        {
            var temp = ds_list_create();
            ds_list_add(temp, 0, keyboard_string);
            net_chat(temp);
        }
    }
    keyboard_string = "";
}
//If user is writing
if(!writing)
{
    keyboard_string = "";
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
