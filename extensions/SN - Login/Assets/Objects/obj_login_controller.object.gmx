        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Login
/*
 * Is called when the clients sends a packet to the server telling it to give the client
 * the salt for the user.
*/
if(salt == "")
{
    alarm[0] = 1;
}
else
{
    net_packet_create("Login");
    net_packet_add(user, sha1_string_utf8(pass + salt));
    net_packet_send();
    user = "";
    pass = "";
    salt = "";
}
</string>
          </argument>
        </arguments>
      </action>
