        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if(net_is_server())
    exit;

if(preX != mouse_x ||
   preY != mouse_y ||
   preLeft != left ||
   preMiddle != middle ||
   preRight != right)
{
    net_packet_create("Mouse");
    net_packet_add(mouse_x);
    if(preY != mouse_y ||
       preLeft != left ||
       preMiddle != middle ||
       preRight != right)
        net_packet_add(mouse_y);
        
    if(preLeft != left ||
       preMiddle != middle ||
       preRight != right)
        net_packet_add(left);
        
    if(preMiddle != middle ||
       preRight != right)
        net_packet_add(middle);
        
    if(preRight != right)
        net_packet_add(right);
    
    net_packet_send();
}

preX = mouse_x;
preY = mouse_y;
preLeft = left;
preMiddle = middle;
preRight = right;
</string>
          </argument>
        </arguments>
      </action>
