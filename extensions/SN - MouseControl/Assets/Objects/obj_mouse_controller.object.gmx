            <string>net_packet_identifier_create("Mouse", -1, net_mouse);
preX = 0;
preY = 0;
left = 0;
middle = 0;
right = 0;
preLeft = 0;
preMiddle = 0;
preRight = 0;

//Server
mouse = ds_grid_create(1, 5);
justPressed = ds_grid_create(1, 3);
justReleased = ds_grid_create(1, 3);
/*
 * X: client
 *
 * Y:
 * 0: x
 * 1: y
 * 2: mb_left
 * 3: mb_middle
 * 4: mb_right
*/
</string>
